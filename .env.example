# Copy this file to .env and fill in your values

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_numeric_id_here

ODDS_API_KEY=your_theoddsapi_key_here

# SQLite DB path (default: tennisedge.db in project folder)
# DATABASE_PATH=tennisedge.db

# Your UPI ID shown to users during credit purchase
UPI_ID=your-upi-id@bank

# Set to false when you have real API keys
MOCK_MODE=true
