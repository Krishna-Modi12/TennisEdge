# Copy this file to .env and fill in your values

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_numeric_id_here

ODDS_API_KEY=your_theoddsapi_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=tennisapi1.p.rapidapi.com

# For generating AI text analysis for signals 
HF_TOKEN=your_huggingface_token_here

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/tennisedge

# Free beta Telegram channel (optional but recommended for audience building)
BETA_CHANNEL_LINK=https://t.me/your_beta_channel
BETA_CHANNEL_NAME=TennisEdge Beta

# Set to false when you have real API keys
MOCK_MODE=true
